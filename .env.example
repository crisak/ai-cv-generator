# ============================================================================
# CV Generator - Environment Variables Example
# ============================================================================
#
# Copia este archivo a .env.local y rellena tus valores:
#   cp .env.example .env.local
#
# NUNCA commitees .env.local a git (ya está en .gitignore)
# ============================================================================

# ──────────────────────────────────────────────────────────────────────────
# CLERK — Autenticación (requeridas)
# Obtén las keys en: https://dashboard.clerk.com → API Keys
# ──────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Rutas de redirección (no cambiar)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/applications
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/applications

# ──────────────────────────────────────────────────────────────────────────
# CLOUDFLARE BROWSER RENDERING — Scraping de ofertas por URL (opcional)
# Obtén las keys en: https://dash.cloudflare.com → Workers & Pages → Browser Rendering
# ──────────────────────────────────────────────────────────────────────────

CF_ACCOUNT_ID=
CF_API_TOKEN=

# ──────────────────────────────────────────────────────────────────────────
# NOTAS
# ──────────────────────────────────────────────────────────────────────────
#
# API KEYS DE IA (Claude, DeepSeek, GPT, etc.):
#   Las configura cada usuario en la app → /settings
#   Se almacenan en IndexedDB local del navegador
#   NO van aquí ni en variables de servidor
#
# PRODUCCIÓN:
#   Usar keys pk_live_ / sk_live_ de Clerk (no pk_test_)
#   Ver DEPLOYMENT_CHECKLIST.md para el proceso completo
#
# VERIFICACIONES:
#   npm audit              # Vulnerabilidades de dependencias
#   npm run format:check   # Formato
#   npm run lint           # ESLint
#   npm run build          # Compilación
#
